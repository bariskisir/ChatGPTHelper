{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ChatGPT Helper",
  "version": "1.0.2",
  "identifier": "com.bariskisir.chatgpthelper",
  "build": {
    "beforeDevCommand": "npm run watch",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ChatGPT Helper",
        "width": 560,
        "height": 520,
        "minWidth": 460,
        "minHeight": 360,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
