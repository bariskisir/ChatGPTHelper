{
  "private": true,
  "scripts": {
    "build": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& './scripts/prepare-dist.ps1'; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; & './node_modules/.bin/tsc.cmd'\"",
    "watch": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& './scripts/prepare-dist.ps1'; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; & './node_modules/.bin/tsc.cmd' --watch\""
  },
  "devDependencies": {
    "tesseract.js": "^7.0.0",
    "typescript": "^5.8.0"
  }
}
